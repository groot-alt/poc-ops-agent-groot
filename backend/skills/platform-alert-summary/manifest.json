{
  "skillId": "platform-alert-summary-read",
  "version": "1.0.0",
  "displayName": "平台告警摘要",
  "description": "读取平台当前活跃告警并按严重级别汇总。",
  "category": "PLATFORM_OBSERVABILITY",
  "riskLevel": "READ_ONLY",
  "executor": "HTTP",
  "outputType": "JSON",
  "readOnly": true,
  "timeoutSeconds": 20,
  "owner": "platform-observability",
  "requiredRoles": ["ROLE_ops-reader", "ROLE_ops-admin"],
  "tags": ["platform", "alert", "summary"],
  "interceptors": ["AUTHORIZATION", "AUDIT", "SENSITIVE_DATA_MASKING"],
  "parameters": [
    {
      "name": "severity",
      "displayName": "最低严重级别",
      "description": "仅返回达到指定严重级别的活跃告警。",
      "type": "ENUM",
      "required": false,
      "allowedValues": ["INFO", "WARNING", "CRITICAL"],
      "defaultValue": "WARNING"
    }
  ]
}
