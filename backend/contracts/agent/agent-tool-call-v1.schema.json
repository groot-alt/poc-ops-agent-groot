{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/contracts/agent/agent-tool-call-v1.schema.json",
  "title": "Agent tool call v1",
  "description": "主 Agent Runtime 请求调用只读 Skill Tool 的强类型信封。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "toolCallId",
    "taskId",
    "workflowId",
    "stepSequence",
    "skill",
    "targetEnvironment",
    "parameters",
    "parametersHash",
    "policyDecision",
    "trace",
    "requestedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "toolCallId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "workflowId": { "type": "string", "minLength": 1 },
    "stepSequence": { "type": "integer", "minimum": 1 },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skillId", "version", "parameterSchemaId", "outputSchemaId"],
      "properties": {
        "skillId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "parameterSchemaId": { "type": "string", "minLength": 1 },
        "outputSchemaId": { "type": "string", "minLength": 1 }
      }
    },
    "targetEnvironment": { "type": "string", "minLength": 1 },
    "parameters": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "parametersHash": { "type": "string", "minLength": 1 },
    "policyDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisionId", "policyVersion", "decision"],
      "properties": {
        "decisionId": { "type": "string", "minLength": 1 },
        "policyVersion": { "type": "string", "minLength": 1 },
        "decision": { "const": "ALLOW" }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceId", "requestId"],
      "properties": {
        "traceId": { "type": "string", "minLength": 1 },
        "requestId": { "type": "string", "minLength": 1 }
      }
    },
    "requestedAt": { "type": "string", "format": "date-time" }
  }
}
