{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/contracts/agent/agent-task-request-v1.schema.json",
  "title": "Agent task request v1",
  "description": "控制面提交给主 Agent Runtime 的只读诊断任务请求。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskId",
    "idempotencyKey",
    "workspace",
    "operator",
    "targetEnvironment",
    "userIntent",
    "inputParameters",
    "policyDecision",
    "trace",
    "requestedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "taskId": { "type": "string", "minLength": 1 },
    "idempotencyKey": { "type": "string", "minLength": 1, "maxLength": 200 },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspaceId", "workspaceCode", "displayName"],
      "properties": {
        "workspaceId": { "type": "string", "minLength": 1 },
        "workspaceCode": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 }
      }
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operatorId", "roles"],
      "properties": {
        "operatorId": { "type": "string", "minLength": 1 },
        "roles": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "targetEnvironment": { "type": "string", "minLength": 1 },
    "userIntent": { "type": "string", "minLength": 1 },
    "inputParameters": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "policyDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisionId", "policyVersion", "decision"],
      "properties": {
        "decisionId": { "type": "string", "minLength": 1 },
        "policyVersion": { "type": "string", "minLength": 1 },
        "decision": { "const": "ALLOW" }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceId", "requestId"],
      "properties": {
        "traceId": { "type": "string", "minLength": 1 },
        "requestId": { "type": "string", "minLength": 1 }
      }
    },
    "requestedAt": { "type": "string", "format": "date-time" }
  }
}
