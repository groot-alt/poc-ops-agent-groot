{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/contracts/agent/agent-task-result-v1.schema.json",
  "title": "Agent task result v1",
  "description": "主 Agent Runtime 返回给工作流的最终任务结果。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskId",
    "workflowId",
    "status",
    "summary",
    "toolCallCount",
    "completedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "taskId": { "type": "string", "minLength": 1 },
    "workflowId": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["SUCCEEDED", "FAILED", "REJECTED", "TIMEOUT"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "toolCallCount": { "type": "integer", "minimum": 0 },
    "completedAt": { "type": "string", "format": "date-time" }
  }
}
