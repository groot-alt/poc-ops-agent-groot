{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/contracts/workflow/read-only-command-v1.schema.json",
  "title": "Read-only command envelope v1",
  "description": "控制面向执行 Worker 提交的已授权只读命令信封。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "commandId",
    "workflowId",
    "idempotencyKey",
    "operationClass",
    "targetEnvironment",
    "skill",
    "parameters",
    "operator",
    "policyDecision",
    "trace",
    "requestedAt"
  ],
  "properties": {
    "contractVersion": { "const": "1.0" },
    "commandId": { "type": "string", "format": "uuid" },
    "workflowId": { "type": "string", "format": "uuid" },
    "idempotencyKey": { "type": "string", "minLength": 1, "maxLength": 200 },
    "operationClass": { "const": "READ_ONLY" },
    "targetEnvironment": { "type": "string", "minLength": 1 },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skillId", "version", "parameterSchemaId", "outputSchemaId"],
      "properties": {
        "skillId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "parameterSchemaId": { "type": "string", "minLength": 1 },
        "outputSchemaId": { "type": "string", "minLength": 1 }
      }
    },
    "parameters": { "type": "object" },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operatorId", "roles"],
      "properties": {
        "operatorId": { "type": "string", "minLength": 1 },
        "roles": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "policyDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisionId", "policyVersion", "decision"],
      "properties": {
        "decisionId": { "type": "string", "minLength": 1 },
        "policyVersion": { "type": "string", "minLength": 1 },
        "decision": { "const": "ALLOW" }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceId", "requestId"],
      "properties": {
        "traceId": { "type": "string", "minLength": 1 },
        "requestId": { "type": "string", "minLength": 1 }
      }
    },
    "requestedAt": { "type": "string", "format": "date-time" }
  }
}
