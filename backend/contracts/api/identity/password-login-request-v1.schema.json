{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/contracts/api/identity/password-login-request-v1.schema.json",
  "title": "Password login request v1",
  "description": "内建身份提供方的用户名密码登录请求。",
  "type": "object",
  "additionalProperties": false,
  "required": ["username", "password"],
  "properties": {
    "username": { "type": "string", "minLength": 1, "maxLength": 120 },
    "password": { "type": "string", "minLength": 1, "maxLength": 512 }
  }
}
