{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/contracts/api/identity/password-login-response-v1.schema.json",
  "title": "Password login response v1",
  "description": "内建身份提供方的用户名密码登录响应。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authenticated",
    "roles",
    "passwordChangeRequired"
  ],
  "properties": {
    "authenticated": { "type": "boolean" },
    "subject": { "type": ["string", "null"], "minLength": 1 },
    "username": { "type": ["string", "null"], "minLength": 1 },
    "roles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "passwordChangeRequired": { "type": "boolean" }
  }
}
