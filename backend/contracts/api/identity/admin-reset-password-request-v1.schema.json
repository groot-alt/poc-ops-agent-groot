{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/contracts/api/identity/admin-reset-password-request-v1.schema.json",
  "title": "Admin reset password request v1",
  "description": "管理员受控重置密码请求。",
  "type": "object",
  "additionalProperties": false,
  "required": ["accountId", "reason", "temporaryPassword", "forcePasswordChange"],
  "properties": {
    "accountId": { "type": "string", "minLength": 1, "maxLength": 120 },
    "reason": { "type": "string", "minLength": 1, "maxLength": 500 },
    "temporaryPassword": { "type": "string", "minLength": 1, "maxLength": 200 },
    "forcePasswordChange": { "type": "boolean" }
  }
}
