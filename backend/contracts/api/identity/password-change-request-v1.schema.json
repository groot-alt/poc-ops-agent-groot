{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/ops-agent/contracts/api/identity/password-change-request-v1.schema.json",
  "title": "Password change request v1",
  "description": "首次登录改密或主动修改密码请求。",
  "type": "object",
  "additionalProperties": false,
  "required": ["currentPassword", "newPassword"],
  "properties": {
    "currentPassword": { "type": "string", "minLength": 1, "maxLength": 512 },
    "newPassword": { "type": "string", "minLength": 1, "maxLength": 512 }
  }
}
